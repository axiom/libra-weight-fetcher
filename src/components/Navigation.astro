---
const currentPath = Astro.url.pathname;
const queryString = Astro.url.search;

const navItems = [
  { href: `/`, label: "Home", path: "/" },
  { href: `/chart${queryString}`, label: "Chart", path: "/chart" },
  { href: `/calendar${queryString}`, label: "Calendar", path: "/calendar" },
];
---

<nav class="w-full border-b-2 border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 shadow-sm">
  <div class="flex gap-6 px-8 py-4 max-w-4xl mx-auto">
    {navItems.map((item) => (
      <a 
        href={item.href}
        class="no-underline text-gray-900 dark:text-gray-100 font-medium py-2 border-b-2 border-transparent hover:border-orange-500 dark:hover:border-orange-500 transition-colors duration-200 data-[current=true]:border-orange-500"
        data-current={currentPath === item.path || currentPath === item.path + '/'}
      >
        {item.label}
      </a>
    ))}
  </div>
</nav>
